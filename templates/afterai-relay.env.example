# afterai-relay local runtime config. Copy to .env and edit. Do not commit .env.
AFTERAI_RELAY_BACKEND=auto
AFTERAI_RELAY_HOST=127.0.0.1
AFTERAI_RELAY_PORT=18800
AFTERAI_RELAY_PROFILE=default
# AFTERAI_RELAY_PROFILE_DIR=$HOME/.local/share/afterai-relay/profiles/default
AFTERAI_RELAY_DISPLAY=:1002
AFTERAI_RELAY_HEADLESS=0
AFTERAI_RELAY_LAUNCH_TIMEOUT=60

# Optional explicit browser binaries.
# AFTERAI_RELAY_CLOAK_BIN=$HOME/.local/bin/cloakbrowser-chrome
# AFTERAI_RELAY_BROWSEROS_BIN=/usr/bin/browseros
# AFTERAI_RELAY_CHROMIUM_BIN=/usr/bin/chromium

# Optional unauthenticated proxy for a rail. URL paths/query strings are ignored.
# Authenticated proxies are rejected until a secure browser-auth flow is implemented.
# AFTERAI_RELAY_PROXY=http://proxy.example:8080

# Upload helpers accept only absolute non-symlinked files below these roots.
# AFTERAI_RELAY_UPLOAD_ALLOWED_DIRS=/absolute/approved/uploads:/another/approved/root

# CloakBrowser wrapper settings.
CLOAKBROWSER_CACHE_DIR=$HOME/.local/share/afterai-relay/cloakbrowser-cache
CLOAKBROWSER_FINGERPRINT_PLATFORM=windows
# Persistent authenticated rails keep one stable fingerprint configuration.
# Do not rotate this seed during an active profile lifetime.
# CLOAKBROWSER_FINGERPRINT_SEED=12345
